// Schema do RunUp — MVP1.
// Modelo validado em docs/plans/2026-07-04-runup-design.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  coach
}

enum AuthProvider {
  email
  google
  strava
}

enum CoachStudentStatus {
  pending
  active
  ended
}

enum InvitedBy {
  coach
  student
}

enum SubscriptionTier {
  free
  pro
  elite
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

enum PlanType {
  generic
  custom
}

enum WorkoutDayStatus {
  pending
  done
  partial
  skipped
}

enum WorkoutLogSource {
  manual
  strava
  health_connect
}

enum GoalStatus {
  active
  achieved
  abandoned
}

enum WorkoutLogKind {
  running
  strength
  mobility
  bike
  walk
  other
}

enum RaceStatus {
  interested
  registered
  completed
}

enum Sex {
  male
  female
  other
}

enum ExperienceLevel {
  beginner
  intermediate
  advanced
}

enum MissionPeriod {
  daily
  weekly
}

model User {
  id           String       @id @default(uuid())
  role         UserRole
  name         String
  email        String       @unique
  avatarUrl    String?
  authProvider AuthProvider @default(email)
  // Nulo para contas criadas via OAuth (Google/Strava).
  passwordHash String?
  createdAt    DateTime     @default(now())

  coachLinks     CoachStudent[]    @relation("CoachLinks")
  studentLinks   CoachStudent[]    @relation("StudentLinks")
  ownedPlans     Plan[]
  subscription   Subscription?
  workoutLogs    WorkoutLog[]
  bodyMetrics    BodyMetric[]
  personalBests  PersonalRecord[]
  goals          Goal[]
  sentMessages   Message[]
  templates      WorkoutTemplate[]
  stravaLink     StravaConnection?
  refreshTokens  RefreshToken[]
  athleteProfile AthleteProfile?
  athleteProgress AthleteProgress?
  shoes          Shoe[]
  races          Race[]
  achievements   Achievement[]
  missions       Mission[]
  pushTokens     PushToken[]
  notifications  Notification[]
}

/** Notificação in-app — gravada nos mesmos pontos que já disparam push. */
model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/** Token de push (Expo) — um dispositivo pode registrar mais de um ao longo do tempo. */
model PushToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  // Guarda apenas o hash do token — o valor bruto vive só no cliente.
  tokenHash String    @unique
  expiresAt DateTime
  // Rotação: quando usado, marca-se revogado e emite-se um novo.
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CoachStudent {
  id          String             @id @default(uuid())
  coach       User               @relation("CoachLinks", fields: [coachId], references: [id])
  coachId     String
  student     User               @relation("StudentLinks", fields: [studentId], references: [id])
  studentId   String
  status      CoachStudentStatus @default(pending)
  // Quem iniciou o convite — decide quem precisa aceitar/recusar (a outra parte).
  initiatedBy InvitedBy          @default(coach)
  createdAt   DateTime           @default(now())
  messages    Message[]

  @@unique([coachId, studentId])
  @@index([coachId])
  @@index([studentId])
}

model Subscription {
  id               String             @id @default(uuid())
  coach            User               @relation(fields: [coachId], references: [id])
  coachId          String             @unique
  tier             SubscriptionTier   @default(free)
  status           SubscriptionStatus @default(active)
  currentPeriodEnd DateTime?
}

model Plan {
  id            String           @id @default(uuid())
  owner         User             @relation(fields: [ownerId], references: [id])
  ownerId       String
  type          PlanType         @default(custom)
  title         String
  durationWeeks Int
  createdAt     DateTime         @default(now())
  workoutDays   WorkoutDay[]
  assignments   PlanAssignment[]
  goals         Goal[]
}

model PlanAssignment {
  id        String   @id @default(uuid())
  plan      Plan     @relation(fields: [planId], references: [id])
  planId    String
  studentId String
  startDate DateTime

  @@index([studentId])
}

model WorkoutDay {
  id       String           @id @default(uuid())
  plan     Plan             @relation(fields: [planId], references: [id])
  planId   String
  week     Int
  date     DateTime
  status   WorkoutDayStatus @default(pending)
  // Blocos e itens guardados como JSON (estrutura em @runup/types).
  blocks   Json
  // Dia de recuperação obrigatória (ex.: após treino de alta carga) — indicador visual no calendário.
  mandatoryRecovery Boolean @default(false)
  logs     WorkoutLog[]
  comments WorkoutComment[]

  @@index([planId])
}

model Exercise {
  id          String  @id @default(uuid())
  name        String
  muscleGroup String?
  mediaUrl    String?
}

model WorkoutTemplate {
  id       String @id @default(uuid())
  owner    User   @relation(fields: [ownerId], references: [id])
  ownerId  String
  title    String
  category String
  blocks   Json

  @@index([ownerId])
}

model WorkoutLog {
  id                String           @id @default(uuid())
  // Opcional: atividades avulsas do Strava (sem dia planejado) têm dia nulo.
  workoutDay        WorkoutDay?      @relation(fields: [workoutDayId], references: [id])
  workoutDayId      String?
  student           User             @relation(fields: [studentId], references: [id])
  studentId         String
  source            WorkoutLogSource @default(manual)
  // Tipo de atividade — permite filtrar o histórico (corrida/musculação/bike/...)
  // e distinguir os dois treinos de um mesmo dia (ex.: corrida + musculação).
  kind              WorkoutLogKind   @default(running)
  // Id da atividade no Strava — evita importar a mesma atividade duas vezes.
  stravaActivityId  String?          @unique
  // Id da sessão de exercício no Health Connect — mesma ideia do Strava acima.
  healthConnectId   String?          @unique
  completedAt       DateTime         @default(now())
  distanceMeters    Int?
  durationSeconds   Int?
  avgPaceSecPerKm   Int?
  avgHeartRate      Int?
  cadence           Int?
  elevationGainM    Int?
  splits            Json?
  caloriesKcal      Int?
  // Texto livre (ex.: "22°C, ensolarado") — sem integração com provedor de clima ainda.
  weather           String?
  // Nome da atividade no Strava (ex.: "Corrida matinal") — só quando vem de lá.
  stravaName        String?
  // Traçado da corrida, no formato encoded polyline do Google/Strava.
  mapPolyline       String?
  shoe              Shoe?            @relation(fields: [shoeId], references: [id])
  shoeId            String?
  perceivedEffort   Int?
  pain              String?
  notes             String?

  @@index([studentId])
  @@index([workoutDayId])
  @@index([shoeId])
}

model BodyMetric {
  id         String   @id @default(uuid())
  student    User     @relation(fields: [studentId], references: [id])
  studentId  String
  date       DateTime
  weightKg   Float?
  bodyFatPct Float?

  @@index([studentId])
}

model PersonalRecord {
  id          String   @id @default(uuid())
  student     User     @relation(fields: [studentId], references: [id])
  studentId   String
  distance    String
  timeSeconds Int
  achievedAt  DateTime

  @@unique([studentId, distance])
}

model Goal {
  id                String     @id @default(uuid())
  student           User       @relation(fields: [studentId], references: [id])
  studentId         String
  plan              Plan?      @relation(fields: [planId], references: [id])
  planId            String?
  targetRace        String
  raceName          String?
  raceDate          DateTime
  targetTimeSeconds Int?
  status            GoalStatus @default(active)

  @@index([studentId])
}

model Message {
  id             String       @id @default(uuid())
  coachStudent   CoachStudent @relation(fields: [coachStudentId], references: [id])
  coachStudentId String
  sender         User         @relation(fields: [senderId], references: [id])
  senderId       String
  text           String
  sentAt         DateTime     @default(now())
  readAt         DateTime?

  @@index([coachStudentId])
}

model WorkoutComment {
  id           String     @id @default(uuid())
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id])
  workoutDayId String
  authorId     String
  text         String
  createdAt    DateTime   @default(now())

  @@index([workoutDayId])
}

model StravaConnection {
  id           String   @id @default(uuid())
  student      User     @relation(fields: [studentId], references: [id])
  studentId    String   @unique
  athleteId    String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  connectedAt  DateTime @default(now())
}

/** Dados estáticos do atleta (tela Perfil > Informações) — separado de `BodyMetric`, que é a série histórica de peso. */
model AthleteProfile {
  id                     String           @id @default(uuid())
  student                User             @relation(fields: [studentId], references: [id])
  studentId              String           @unique
  heightCm               Float?
  birthDate              DateTime?
  sex                    Sex?
  hrMaxBpm               Int?
  vo2max                 Float?
  experience             ExperienceLevel?
  weeklyAvailabilityDays Int?
  updatedAt              DateTime         @updatedAt
}

/** Progresso de gamificação (XP/nível) — 1 registro por aluno. */
model AthleteProgress {
  id        String   @id @default(uuid())
  student   User     @relation(fields: [studentId], references: [id])
  studentId String   @unique
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

/** Conquista desbloqueada (ex.: "first_5k", "100km_total"). */
model Achievement {
  id         String   @id @default(uuid())
  student    User     @relation(fields: [studentId], references: [id])
  studentId  String
  code       String
  achievedAt DateTime @default(now())

  @@unique([studentId, code])
  @@index([studentId])
}

/** Missão diária/semanal (ex.: "correr 3x esta semana"). */
model Mission {
  id          String        @id @default(uuid())
  student     User          @relation(fields: [studentId], references: [id])
  studentId   String
  code        String
  period      MissionPeriod
  // Dia (missão diária) ou início da semana (missão semanal) a que se refere.
  targetDate  DateTime
  progress    Int           @default(0)
  target      Int
  completedAt DateTime?

  @@unique([studentId, code, targetDate])
  @@index([studentId])
}

/** Tênis de corrida — km acumulado e alerta de vida útil. */
model Shoe {
  id        String       @id @default(uuid())
  student   User         @relation(fields: [studentId], references: [id])
  studentId String
  name      String
  brand     String?
  model     String?
  color     String?
  totalKm   Float        @default(0)
  // Limite de km a partir do qual o app avisa pra trocar de tênis (ex.: 600/800/1000).
  alertKm   Int?
  retiredAt DateTime?
  createdAt DateTime     @default(now())
  logs      WorkoutLog[]

  @@index([studentId])
}

/** Prova cadastrada pelo aluno — usada pro ícone de medalha no calendário e contagem regressiva. */
model Race {
  id                String     @id @default(uuid())
  student           User       @relation(fields: [studentId], references: [id])
  studentId         String
  name              String
  city              String?
  state             String?
  raceDate          DateTime
  startTime         String?
  distanceMeters    Int?
  targetTimeSeconds Int?
  courseUrl         String?
  registrationUrl   String?
  status            RaceStatus @default(interested)
  // Só uma prova alvo por aluno por vez (garantido por índice único parcial
  // na migration — o Prisma não modela índice parcial no schema).
  isTarget          Boolean    @default(false)
  createdAt         DateTime   @default(now())

  @@index([studentId])
  @@index([raceDate])
}
