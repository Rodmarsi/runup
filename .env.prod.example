# Produção (VPS) — copie para ".env" ao lado do docker-compose.prod.yml e preencha.
# NUNCA comite o .env preenchido.

# --- Banco ---
POSTGRES_USER=runup
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=runup

# --- Segurança ---
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-aleatorio

# --- Domínios (aponte o DNS deles para o IP da VPS) ---
API_DOMAIN=api.seudominio.com
WEB_DOMAIN=app.seudominio.com
API_ORIGIN=https://api.seudominio.com
WEB_ORIGIN=https://app.seudominio.com

# --- Integrações (as mesmas do dev; troque os redirects nos painéis para as URLs de produção) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
