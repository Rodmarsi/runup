{
  "expo": {
    "name": "RunUp",
    "slug": "runup",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121110",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.runup.app"
    },
    "android": {
      "package": "com.runup.app"
    },
    "extra": {
      "eas": {
        "projectId": "78af50a9-7d2f-46e7-bf4b-ecf707e51d69"
      }
    },
    "owner": "rodmarsi",
    "newArchEnabled": false,
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ]
  }
}
